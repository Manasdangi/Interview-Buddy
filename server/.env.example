GEMINI_API_KEY=your_gemini_api_key_here
PORT=4000

# Firestore persistence. Use either the split service account vars:
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_service_account_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key\n-----END PRIVATE KEY-----\n"

# Or one JSON/base64 service account var instead of the split vars:
# FIREBASE_SERVICE_ACCOUNT_JSON={"project_id":"...","client_email":"...","private_key":"..."}
# FIREBASE_SERVICE_ACCOUNT_BASE64=base64_encoded_service_account_json

FIRESTORE_INTERVIEW_SESSIONS_COLLECTION=interviewSessions
FIRESTORE_INTERVIEW_SUMMARIES_COLLECTION=userInterviewSummaries
